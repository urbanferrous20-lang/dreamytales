# Copy to .env.local and fill in your values. NEVER commit .env.local

# Local dev — use http://localhost:3000. Production: https://dreamytales.co.za
NEXT_PUBLIC_APP_URL=https://dreamytales.co.za

# Server-only secrets — no NEXT_PUBLIC_ prefix
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
AUTH_SECRET=generate-a-long-random-string-here
CRON_SECRET=generate-another-long-random-string-here

# MySQL (create database in Plesk → Databases)
# Format: mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME
DATABASE_URL="mysql://dreamytales:CHANGE_ME@localhost:3306/dreamytales"

# 1-grid SMTP (mail.dreamytales.co.za — create mailbox Admin@ in Plesk first)
SMTP_HOST=mail.dreamytales.co.za
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=Admin@dreamytales.co.za
SMTP_PASS=
SMTP_FROM="Dreamy Tales <Admin@dreamytales.co.za>"
ADMIN_EMAIL=Admin@dreamytales.co.za
# Local dev — plain password (Next.js cannot load bcrypt hashes with $ in .env files)
ADMIN_PASSWORD=
# Production / Plesk — use base64 hash from: npm run admin:hash-password -- "your-password"
ADMIN_PASSWORD_HASH_B64=

# Storage (admin dashboard estimates + PDF cleanup)
PDF_RETENTION_DAYS=90
STORAGE_QUOTA_GB=25
