# Copy to .env.local and fill in your values. NEVER commit .env.local

# Local dev — use http://localhost:3000. Production: https://dreamytales.co.za
NEXT_PUBLIC_APP_URL=https://dreamytales.co.za

# Meta Pixel (public — browser tracking for Facebook/Instagram ads)
NEXT_PUBLIC_META_PIXEL_ID=1540964337753091

# Server-only secrets — no NEXT_PUBLIC_ prefix
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# Afrikaans narration — native af-ZA pronunciation (recommended). Enable Cloud Text-to-Speech API, create an API key.
# Without this, Afrikaans falls back to OpenAI which often sounds Dutch.
GOOGLE_TTS_API_KEY=
# Story illustrations: low | medium | high | auto (default low — cheapest; ~$0.005/image at 1024²)
ILLUSTRATION_OPENAI_QUALITY=low
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
AUTH_SECRET=generate-a-long-random-string-here
CRON_SECRET=generate-another-long-random-string-here

# Nightly story emails: earliest send time in SAST (default 16 = 4pm). Optional end hour (e.g. 22).
STORY_DELIVERY_START_HOUR_SAST=16
# STORY_DELIVERY_END_HOUR_SAST=22
# STORY_DELIVERY_ENFORCE=false

# MySQL (create database in Plesk → Databases)
# Format: mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME
DATABASE_URL="mysql://dreamytales:CHANGE_ME@localhost:3306/dreamytales"

# 1-grid SMTP (create mailbox Admin@dreamytales.co.za in Plesk → Mail first)
SMTP_HOST=mail.dreamytales.co.za
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=Admin@dreamytales.co.za
SMTP_PASS=your-mailbox-password-here
SMTP_FROM="Dreamy Tales <Admin@dreamytales.co.za>"
# If TLS fails on Plesk, try: SMTP_TLS_REJECT_UNAUTHORIZED=false
# Alternative port: SMTP_PORT=587 SMTP_SECURE=false
ADMIN_EMAIL=Admin@dreamytales.co.za
# Local dev — plain password (Next.js cannot load bcrypt hashes with $ in .env files)
ADMIN_PASSWORD=
# Production / Plesk — use base64 hash from: npm run admin:hash-password -- "your-password"
ADMIN_PASSWORD_HASH_B64=

# Storage (admin dashboard estimates + PDF cleanup)
PDF_RETENTION_DAYS=90
STORAGE_QUOTA_GB=25

# Admin dashboard subscriber goal (default 10000)
SUBSCRIBER_GOAL=10000
