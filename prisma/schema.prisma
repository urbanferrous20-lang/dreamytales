generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  signupRef    String?        @unique
  affiliateCode String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  children     ChildProfile[]
  subscription Subscription?
  storyReviews StoryReview[]
  siteReview   SiteReview?
  payments     Payment[]
  passwordResetTokens PasswordResetToken[]
  affiliateConversion AffiliateConversion?

  @@index([affiliateCode])
}

model StoryReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, storyId])
}

model SiteReview {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChildProfile {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  age            Int
  birthDate      DateTime? @db.Date
  pronouns       String
  interests      String   @db.Text
  favoriteColors String
  favoriteToy    String?
  petInfo        String?
  siblingNames   String?
  bestFriend     String?
  favoritePlace  String?
  province       String   @default("Gauteng")
  cityOrTown     String   @default("Johannesburg")
  customCity     String?
  suburb         String?
  topicsToAvoid  String?
  storyMood      String   @default("gentle")
  moralTheme     String?
  readAloudBy     String   @default("parent")
  language       String   @default("english")
  characterBible String?  @db.Text
  styleAnchorUrl String?
  petAnchorUrl   String?
  petAnchorSource String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  stories        Story[]
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             String    @default("pending")
  payfastToken       String?
  recurringAmount    Float
  childCount         Int       @default(1)
  billingInterval    String    @default("monthly")
  trialEndsAt        DateTime?
  nextBillingDate    DateTime?
  cancelRequestedAt  DateTime?
  accessEndsAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Story {
  id        String       @id @default(cuid())
  childId   String
  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  title     String
  summary   String   @db.Text
  settingKey String?
  archetypeKey String?
  inspirationKey String?
  isBirthdayStory Boolean @default(false)
  pdfPath   String
  storyDate DateTime
  sentAt    DateTime?
  createdAt DateTime     @default(now())
  reviews   StoryReview[]

  @@unique([childId, storyDate])
}

model PendingSignup {
  id        String   @id @default(cuid())
  email     String
  name      String
  passwordHash String
  childrenJson String @db.Text
  billingInterval String @default("monthly")
  agreedToTerms Boolean @default(false)
  affiliateCode String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  sessionId String
  path      String?
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
  @@index([createdAt])
}

model Payment {
  id               String    @id @default(cuid())
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscriptionId   String?
  payfastPaymentId String?   @unique
  signupId         String?
  amountGross      Float
  amountFee        Float     @default(0)
  paymentStatus    String
  billingDate      DateTime?
  createdAt        DateTime  @default(now())
  affiliateConversion AffiliateConversion?

  @@index([createdAt])
  @@index([paymentStatus, createdAt])
  @@index([signupId])
}

model AffiliatePartner {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  contactName      String?
  contactEmail     String?
  commissionAmount Float    @default(5)
  active           Boolean  @default(true)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  conversions      AffiliateConversion[]
}

model AffiliateConversion {
  id               String   @id @default(cuid())
  partnerId        String
  partner          AffiliatePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  paymentId        String?  @unique
  payment          Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  commissionAmount Float
  convertedAt      DateTime @default(now())
  payoutStatus     String   @default("pending")
  paidAt           DateTime?
  payoutMonth      String?

  @@index([partnerId, convertedAt])
  @@index([payoutStatus, convertedAt])
  @@index([convertedAt])
}
